MSG91_SENDER_ID=PRATND

RESEND_API_KEY=
FRONTEND_URL=http://localhost:3000

#Twilio
Account_SID=
Auth_Token=
TWILIO_WHATSAPP_NUMBER=
TWILIO_PHONE_NUMBER=
