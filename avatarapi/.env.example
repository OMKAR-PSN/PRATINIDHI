#
# COLAB_URL: Paste the Cloudflare tunnel URL from the Colab notebook
#   1. Open colab_notebook.ipynb in Google Colab (GPU runtime)
#   2. Run all cells
#   3. Copy the URL printed in Cell 4 (looks like https://xxx.trycloudflare.com)
#   4. Paste it below
#
COLAB_URL=
EDEN_API_KEY=

# Bhashini API (bhashini.gov.in) — Translation & TTS
BHASHINI_USER_ID=
BHASHINI_API_KEY=
BHASHINI_UDYAT_KEY=
BHASHINI_INFERENCE_KEY=

# Neon PostgreSQL
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# MongoDB Atlas
MONGO_URL=

# Redis
REDIS_URL=

# JWT secret for signing consent tokens and video signatures
JWT_SECRET=

# MSG91 SMS (optional — OTP will print to console if not set)
